GROQ_API_KEY=pega tu clave acá (solo si corrés el servidor en tu compu; para Render, la clave va en el formulario web de Render, no en este archivo)
ELEVENLABS_API_KEY=pega tu clave acá (opcional; sin esto el chat sigue funcionando pero sin voz de IA)
# Opcional: si servís el frontend desde otro dominio propio, agregalo acá
# para que el backend le acepte pedidos (además de GitHub Pages y localhost).
ALLOWED_ORIGIN=
PORT=3000
