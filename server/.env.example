GROQ_API_KEY=pega tu clave acá (solo si corrés el servidor en tu compu; para Render, la clave va en el formulario web de Render, no en este archivo)
ELEVENLABS_API_KEY=pega tu clave acá (opcional; sin esto el chat sigue funcionando pero sin voz de IA)
# voice_id de ElevenLabs en español (Voice Library). Sin ninguna de las
# dos, /tts devuelve un error claro en vez de usar una voz en inglés.
ELEVENLABS_VOICE_ID_HOMBRE=
ELEVENLABS_VOICE_ID_MUJER=
# Opcionales: modelo por contexto y ajustes de voz_settings. Ver README.md
# para los valores por defecto y qué hace cada uno.
ELEVENLABS_MODEL_CHAT=
ELEVENLABS_MODEL_DOCUMENT=
ELEVENLABS_STABILITY=
ELEVENLABS_SIMILARITY=
ELEVENLABS_STYLE=
ELEVENLABS_SPEED=
ELEVENLABS_SPEAKER_BOOST=
# Opcionales: límites de /tts para proteger la cuota gratis de ElevenLabs.
TTS_RATE_LIMIT_PER_MIN=
TTS_DAILY_LIMIT=
# Opcionales: caché en memoria de audio de /tts (Punto 6 de la auditoría
# v2 -- ver README.md). Por defecto 120 entradas / 50MB / 24hs de TTL.
# TTS_CACHE_TTL_MS=0 desactiva la expiración (solo se libera por tope de
# entradas/bytes, nunca por tiempo).
TTS_CACHE_MAX_ENTRADAS=
TTS_CACHE_MAX_BYTES=
TTS_CACHE_TTL_MS=
# Opcional: si servís el frontend desde otro dominio propio, agregalo acá
# para que el backend le acepte pedidos (además de GitHub Pages y localhost).
ALLOWED_ORIGIN=
PORT=3000

# === Timeouts + reintentos para Groq/ElevenLabs (opcionales) ===
# Por defecto 20000ms / 2 reintentos. Solo se reintenta ante errores
# recuperables (timeout, caída de conexión, 429/500/502/503/504) -- nunca
# 400, clave inválida ni configuración faltante.
GROQ_TIMEOUT_MS=
GROQ_MAX_RETRIES=
ELEVENLABS_TIMEOUT_MS=
ELEVENLABS_MAX_RETRIES=

# === Turnstile (opcional, Etapa 2 de la auditoría de seguridad) ===
# Protege /ask, /tts, /fetch-document y /voice/piper de scripts
# automatizados. Con TURNSTILE_ENABLED sin definir (o "false"), el
# backend funciona exactamente igual que antes -- pensado a propósito
# para que quede DESACTIVADO por defecto en desarrollo local, y lo actives
# vos mismo cuando despliegues a producción si querés esta capa.
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
# No es secreta (viaja al navegador) -- se expone sola en /health para que
# el frontend la tome automáticamente, no hace falta pegarla a mano.
TURNSTILE_SITE_KEY=
# Opcionales, cada uno solo se aplica si se lo completa:
TURNSTILE_EXPECTED_HOSTNAME=
TURNSTILE_EXPECTED_ACTION=
# Turnstile estándar no devuelve un campo de "score" (a diferencia de
# reCAPTCHA v3) -- esta variable queda sin efecto salvo que la respuesta
# de Cloudflare sí lo incluya (por ejemplo, algún tier Enterprise).
TURNSTILE_MIN_SCORE=
TURNSTILE_TIMEOUT_MS=

# === Rate limiting (Etapa 3 de la auditoría de seguridad / Punto 3 v2) ===
# Ver README.md, sección "Rate limiting y sesión anónima firmada" -- valores
# por defecto ya razonables, no hace falta tocar esto salvo que quieras
# ajustarlos.
# Sin definir, se activa solo si RENDER=true (Render lo pone solo). Ponela en
# "true" si desplegás detrás de otro proxy reverso, o en "false" para
# desactivarla explícitamente. Necesaria para que req.ip sea la IP real del
# visitante y no la del proxy -- sin esto, el rate limit por IP termina
# siendo un único cupo compartido por todo el mundo.
TRUST_PROXY=
RATE_LIMIT_SESSION_SECRET=
ASK_MAX_CHARACTERS_POR_MINUTO=
TTS_MAX_CHARACTERS_POR_MINUTO=

# === Voz local con Piper (motor aparte de ElevenLabs, gratis y sin cuota) ===
# Ver server/src/voice/README.md para instalación, licencias y voces en
# español disponibles. Ojo: aunque el nombre empieza igual, estas variables
# NO tienen nada que ver con TTS_RATE_LIMIT_PER_MIN/TTS_DAILY_LIMIT de
# arriba (esas son solo para /tts, o sea ElevenLabs).
TTS_ENABLED=false
TTS_ENGINE=piper
PIPER_EXECUTABLE=
PIPER_MODEL_PATH=
PIPER_CONFIG_PATH=
PIPER_OUTPUT_DIRECTORY=
TTS_AUTOPLAY=false
# Cuántas síntesis de Piper corren en paralelo (cada una es un proceso
# aparte) y cuántas más esperan en cola antes de responder 429/503 con un
# error claro. Por defecto 2 / 5.
PIPER_MAX_CONCURRENCIA=
PIPER_MAX_EN_COLA=
